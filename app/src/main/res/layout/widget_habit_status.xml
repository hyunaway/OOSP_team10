<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_background"
    android:padding="12dp">

    <TextView
        android:id="@+id/titleText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="해빗프렌즈"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="#FF212121" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="4dp">

        <TextView
            android:id="@+id/avatarText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="😐"
            android:textSize="28sp"
            android:layout_marginEnd="8dp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/waterText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="💧 물: 0ml"
                android:textSize="12sp"
                android:textColor="#FF424242" />

            <TextView
                android:id="@+id/speechText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="좋아요. 지금 물 섭취 리듬은 괜찮아요."
                android:textSize="10sp"
                android:maxLines="2"
                android:ellipsize="end"
                android:textColor="#FFD32F2F"
                android:layout_marginTop="2dp" />

            <TextView
                android:id="@+id/stretchText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🧘 스트레칭: 0회"
                android:textSize="12sp"
                android:textColor="#FF424242"
                android:layout_marginTop="2dp" />

        </LinearLayout>

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="8dp">

        <Button
            android:id="@+id/addWaterButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="💧 +250ml"
            android:textSize="11sp"
            android:layout_marginEnd="4dp" />

        <Button
            android:id="@+id/stretchButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="🧘 스트레칭"
            android:textSize="11sp"
            android:layout_marginEnd="4dp" />

        <Button
            android:id="@+id/openAppButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="앱 열기"
            android:textSize="11sp" />

    </LinearLayout>

</LinearLayout>
